DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/data_monitor
APP_NAME=Credit Scoring Monitor
APP_VERSION=0.1.0
ENVIRONMENT=local
LOG_LEVEL=INFO
DRIFT_THRESHOLD=0.5
